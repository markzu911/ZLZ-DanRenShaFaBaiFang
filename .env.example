GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
GEMINI_TEXT_MODEL=gemini-flash-latest
SAAS_ORIGIN=https://aibigtree.com

# Optional overrides. Leave blank unless the SaaS platform moves a path.
# SAAS_LAUNCH_URL=/api/tool/launch
# SAAS_VERIFY_URL=/api/tool/verify
# SAAS_CONSUME_URL=/api/tool/consume
# SAAS_UPLOAD_TOKEN_URL=/api/upload/direct-token
# SAAS_UPLOAD_COMMIT_URL=/api/upload/commit

# Optional: set these if your network needs a local proxy to reach Gemini.
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
# NO_PROXY=localhost,127.0.0.1
